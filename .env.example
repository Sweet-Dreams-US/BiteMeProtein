# Bite Me Protein — environment variables
#
# Copy to .env.local for local dev, or set in Vercel Project Settings for
# Preview / Production deploys. Never commit .env.local.

# ─── Supabase ─────────────────────────────────────────────────────────────

# Public client (browser-visible, RLS-gated)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-side (bypasses RLS — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ─── Square ───────────────────────────────────────────────────────────────

# Public (browser-visible, used by Web Payments SDK)
NEXT_PUBLIC_SQUARE_APPLICATION_ID=sq0idp-XXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_SQUARE_LOCATION_ID=LXXXXXXXXXXXXX

# Server-side
SQUARE_ACCESS_TOKEN=YOUR-SQUARE-TOKEN
SQUARE_ENVIRONMENT=sandbox        # "sandbox" or "production"
SQUARE_LOCATION_ID=LXXXXXXXXXXXXX # same value as NEXT_PUBLIC_SQUARE_LOCATION_ID

# ─── Resend (admin email) ─────────────────────────────────────────────────

RESEND_API_KEY=re_XXXXXXXXXXXX
RESEND_FROM_EMAIL=orders@bitemeprotein.com
ADMIN_NOTIFICATION_EMAIL=haley@bitemeprotein.com

# ─── Square webhooks (sub-project 2) ──────────────────────────────────────

# HMAC signature key from Square Dashboard → Webhooks → (your subscription)
# Used by /api/webhooks/square to verify every incoming POST is really from
# Square. Missing/wrong key = all webhooks rejected 401.
SQUARE_WEBHOOK_SIGNATURE_KEY=YOUR-WEBHOOK-KEY

# Optional override for the URL Square signs with. If unset, the request's
# own URL is used (works unless you're behind a proxy that rewrites host).
# SQUARE_WEBHOOK_NOTIFICATION_URL=https://bitemeprotein.com/api/webhooks/square
